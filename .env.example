# Supabase (required for config save/load)
# Get these from: Supabase Dashboard → Project Settings → API
# Use .env for local runs; never commit .env (only .env.example with placeholders).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Optional: Use service key for elevated permissions (not needed for this app)
# SUPABASE_SERVICE_KEY=your-service-role-key
